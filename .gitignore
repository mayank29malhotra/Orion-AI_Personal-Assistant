# =============================================================================
# ORION AI PERSONAL ASSISTANT — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Environment & Secrets
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
google_cred/
credentials.json
token.json

# ---------------------------------------------------------------------------
# Python — bytecode / cache
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pytype/

# ---------------------------------------------------------------------------
# Python — virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.Python

# ---------------------------------------------------------------------------
# Python — distribution / packaging
# ---------------------------------------------------------------------------
build/
dist/
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/
*.whl

# ---------------------------------------------------------------------------
# Python — test / coverage
# ---------------------------------------------------------------------------
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.tox/
.nox/

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log

# ---------------------------------------------------------------------------
# Databases (created at runtime)
# ---------------------------------------------------------------------------
*.db

# ---------------------------------------------------------------------------
# Sandbox — all runtime / user data
# ---------------------------------------------------------------------------
sandbox/

# ---------------------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# OS files
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ---------------------------------------------------------------------------
# Compiled / native extensions
# ---------------------------------------------------------------------------
*.so
*.dll
*.dylib
*.exe

# ---------------------------------------------------------------------------
# Jupyter Notebook
# ---------------------------------------------------------------------------
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# Project-specific exclusions
# ---------------------------------------------------------------------------
# Internal audit & project memory (local-only)
audit.md
project_memory/
master_prompt.txt

# Empty nested clone (should not be tracked)
Orion-AI_Personal-Assistant/

SDE2_UPGRADE_PLAN.md
UPGRADE_PLAN.md